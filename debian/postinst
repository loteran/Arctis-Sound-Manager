#!/bin/sh
set -e

if [ "$1" = "configure" ]; then
    udevadm control --reload-rules 2>/dev/null || true
    udevadm trigger 2>/dev/null || true
    echo ""
    echo "  Arctis Sound Manager installed!"
    echo ""
    echo "  Run 'asm-setup' to complete setup:"
    echo "    - Deploy PipeWire configs (virtual sinks, HeSuVi surround)"
    echo "    - Download the HRIR file for virtual surround"
    echo "    - Enable all required services (arctis-manager, arctis-video-router, filter-chain)"
    echo ""
fi

#DEBHELPER#
exit 0
