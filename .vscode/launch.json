{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Daemon",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/linux_arctis_manager/scripts/daemon.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Main window (no systemd)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/linux_arctis_manager/scripts/gui.py",
            "console": "integratedTerminal",
            "args": ["--no-enforce-systemd"]
        },
        {
            "name": "Main window",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/linux_arctis_manager/scripts/gui.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Systray app",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/linux_arctis_manager/scripts/gui.py",
            "args": ["--systray"],
            "console": "integratedTerminal"
        },
        {
            "name": "Tools: USB arctis devices",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/linux_arctis_manager/scripts/cli.py",
            "args": ["tools", "arctis-devices"],
            "console": "integratedTerminal"
        }
    ]
}
